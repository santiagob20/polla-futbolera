rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función helper para verificar si el usuario logueado es administrador
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Reglas para usuarios (cada usuario puede leer todos, pero solo escribir el propio o si es administrador)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // Reglas para partidos (cualquier usuario logueado puede leerlos, solo admins pueden modificarlos)
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Reglas para predicciones (el dueño puede leer y escribir, admins también pueden escribir y actualizar puntos)
    match /predictions/{predictionId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Reglas para metadatos (cualquier usuario logueado puede leer, admins pueden escribir)
    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
